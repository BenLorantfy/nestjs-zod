{
  "name": "nestjs-zod",
  "description": "All NestJS + Zod utilities you need",
  "version": "0.0.0-set-by-ci",
  "main": "./dist/index.cjs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./dto": {
      "import": {
        "types": "./dist/dto.d.mts",
        "default": "./dist/dto.mjs"
      },
      "require": {
        "types": "./dist/dto.d.cts",
        "default": "./dist/dto.cjs"
      }
    }
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist",
    "logo.svg",
    "img"
  ],
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:BenLorantfy/nestjs-zod.git",
    "directory": "packages/nestjs-zod"
  },
  "author": "Ben Lorantfy <ben@lorantfy.com>",
  "contributors": [
    "Ben Lorantfy <ben@lorantfy.com>",
    "Evgeny Zakharov <to@risen.dev>"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsdown",
    "test": "TZ=UTC jest",
    "lint": "eslint",
    "lint:fix": "eslint  --fix",
    "format:write": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@golevelup/ts-jest": "^3.0.0",
    "@ibm-cloud/openapi-ruleset": "^1.33.8",
    "@nest-zod/z": "workspace:*",
    "@nestjs/common": "^11.1.5",
    "@nestjs/core": "^11.1.5",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/swagger-v7": "npm:@nestjs/swagger@7.4.2",
    "@nestjs/testing": "^11.1.20",
    "@stoplight/spectral-core": "^1.22.0",
    "@stoplight/spectral-rulesets": "^1.22.2",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.2",
    "@types/lodash": "^4.17.23",
    "@types/merge-deep": "^3.0.0",
    "@types/node": "^25.2.3",
    "@types/supertest": "^6.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "esbuild": "^0.27.2",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "express": "^5.2.1",
    "express-openapi-validator": "^5.6.2",
    "globals": "^17.3.0",
    "jest": "^29.5.0",
    "jiti": "^2.7.0",
    "lodash": "^4.17.23",
    "prettier": "^3.8.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsdown": "^0.22.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.56.0",
    "zod": "^4.1.12"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/swagger": "^7.4.2 || ^8.0.0 || ^11.0.0",
    "rxjs": "^7.0.0",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/swagger": {
      "optional": true
    }
  },
  "dependencies": {
    "deepmerge": "^4.3.1"
  }
}